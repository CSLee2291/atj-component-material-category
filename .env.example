# =============================================================================
# ATJ-Component MATERIAL_CATEGORY Auto-Categorization System
# Copy this file to .env and fill in your credentials
# =============================================================================

# --- Denodo REST API (primary data source) ---
DENODO_BASE_URL_ALLPARTS=https://acldtpltfrm-dev:9443/server/dx_ce/ws_allparts_info_for_ce_app
DENODO_BASE_URL_MANUFACTURE=https://acldtpltfrm-dev:9443/server/dx_ce/iv_plm_zagile_manufacture_ce_app
DENODO_USERNAME=your_denodo_username
DENODO_PASSWORD=your_denodo_password
DENODO_ENABLED=true

# --- Power BI Desktop (fallback — only needed when Denodo is down) ---
PBI_ENABLED=false                  # Set to true to enable PBI Desktop as fallback data source
PBI_CONNECTION_STRING=Data Source=localhost:50614;Application Name=MCP-PBIModeling
PBI_CONNECTION_NAME=PBIDesktop-2026_plm_alparts-50614

# --- Azure OpenAI (GPT categorization) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure OpenAI Embedding (category vector DB) ---
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-02-01

# --- Application settings ---
ENV=dev                    # dev=100 items/batch, prod=1000 items/batch
BATCH_SIZE_DEV=100
BATCH_SIZE_PROD=1000

# --- Fuzzy matching ---
TOP_K_SIMILAR=5
MIN_SIMILARITY_SCORE=0.3

# --- Paths ---
OUTPUT_DIR=data/results
BATCH_DIR=data/batches
